---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Emmanuel Gutierrez Pizarro">

  <!-- ENGLISH -->
  <div class="lang-en">
    <div class="container">
      <div class="page-header">
        <h1>Contact</h1>
        <p>If you have a project, a question or a collaboration opportunity, I would be glad to talk.</p>
      </div>
      <section class="contact">
        <div class="contact-grid">
          <a href="mailto:jgutierrez@jpasesorescr.com" class="contact-card">
            <div class="contact-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <h3>Email</h3><p>jgutierrez@jpasesorescr.com</p>
          </a>
          <a href="tel:+50661427330" class="contact-card">
            <div class="contact-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
            <h3>Phone</h3><p>+506 6142-7330</p>
          </a>
          <a href="https://linkedin.com/in/emmanuelgpcr" target="_blank" rel="noopener" class="contact-card">
            <div class="contact-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></div>
            <h3>LinkedIn</h3><p>emmanuelgpcr</p>
          </a>
        </div>
      </section>
      <section class="bio" style="margin-top: 2rem;">
        <p class="section-tag">Location</p>
        <h2 class="section-title">Costa Rica</h2>
        <div style="max-width: 560px;">
          <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.8;">JP Asesores S.R.L. operates from Costa Rica, available for remote work, scheduled field visits and hybrid arrangements according to each project's needs. Experience throughout Costa Rica and the Central American region.</p>
        </div>
      </section>
    </div>
  </div>

