---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function fmtDate(d: Date, locale: string) {
  return d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title="Blog - Emmanuel Gutiérrez Pizarro">

  <!-- ============ ENGLISH ============ -->
  <div class="lang-en">
    <div class="container">
      <div class="page-header">
        <h1>Blog</h1>
        <p>Notes, op-eds and analysis on territorial fiscal intelligence, community data and the political economy of territories.</p>
      </div>

      <section class="pub-section">
        {posts.length === 0 && (
          <p>No posts yet. Stay tuned.</p>
        )}
        {posts.map((post) => (
          <article class="pub-item">
            <div class="pub-meta">
              <h3><a href={`/blog/${post.id}/`}>{post.data.title_en}</a></h3>
              <div class="pub-source">
                {fmtDate(post.data.date, 'en-US')}
                {post.data.original_outlet && ` - Originally in ${post.data.original_outlet}`}
                {post.data.tags.length > 0 && ` - ${post.data.tags.join(' · ')}`}
              </div>
              <p>{post.data.summary_en}</p>
              <a href={`/blog/${post.id}/`} class="pub-action">Read more <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
            </div>
          </article>
        ))}
      </section>
    </div>
  </div>

  <!-- ============ ESPANOL ============ -->
  <div class="lang-es">
    <div class="container">
      <div class="page-header">
        <h1>Blog</h1>
        <p>Notas, columnas y analisis sobre inteligencia fiscal territorial, datos comunitarios y la economia politica de los territorios.</p>
      </div>

      <section class="pub-section">
        {posts.length === 0 && (
          <p>Aun no hay publicaciones. Pronto.</p>
        )}
        {posts.map((post) => (
          <article class="pub-item">
            <div class="pub-meta">
              <h3><a href={`/blog/${post.id}/`}>{post.data.title_es}</a></h3>
              <div class="pub-source">
                {fmtDate(post.data.date, 'es-CR')}
                {post.data.original_outlet && ` - Publicado originalmente en ${post.data.original_outlet}`}
                {post.data.tags.length > 0 && ` - ${post.data.tags.join(' · ')}`}
              </div>
              <p>{post.data.summary_es}</p>
              <a href={`/blog/${post.id}/`} class="pub-action">Leer mas <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
            </div>
          </article>
        ))}
      </section>
    </div>
  </div>

</Layout>
