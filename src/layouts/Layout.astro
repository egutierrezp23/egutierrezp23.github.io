---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Financial, data and territorial intelligence consultant. Subnational fiscal analysis, financial sustainability and results measurement across Costa Rica and Central America.' } = Astro.props;
const path = Astro.url.pathname;
const isActive = (p: string) => path === p ? 'active' : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#185FA5" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      // Aplicar tema e idioma antes del render para evitar parpadeo.
      (function () {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
        var lang = localStorage.getItem('siteLang') || 'en';
        document.documentElement.setAttribute('data-site-lang', lang);
        document.documentElement.setAttribute('lang', lang);
      })();
    </script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">Emmanuel Gutierrez</a>
        <div class="nav-right">
          <ul class="nav-links lang-en">
            <li><a href="/" class={isActive('/')}>Home</a></li>
            <li><a href="/proyectos" class={isActive('/proyectos/')}>Work</a></li>
            <li><a href="/publicaciones" class={isActive('/publicaciones/')}>Publications</a></li>
            <li><a href="/blog" class={path.startsWith('/blog') ? 'active' : ''}>Blog</a></li>
            <li><a href="/trayectoria" class={isActive('/trayectoria/')}>About</a></li>
            <li><a href="/contacto" class={isActive('/contacto/')}>Contact</a></li>
          </ul>
          <ul class="nav-links lang-es">
            <li><a href="/" class={isActive('/')}>Inicio</a></li>
            <li><a href="/proyectos" class={isActive('/proyectos/')}>Proyectos</a></li>
            <li><a href="/publicaciones" class={isActive('/publicaciones/')}>Publicaciones</a></li>
            <li><a href="/blog" class={path.startsWith('/blog') ? 'active' : ''}>Blog</a></li>
            <li><a href="/trayectoria" class={isActive('/trayectoria/')}>Trayectoria</a></li>
            <li><a href="/contacto" class={isActive('/contacto/')}>Contacto</a></li>
          </ul>
          <button class="lang-switch" id="langSwitch" aria-label="Change language">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span id="langLabel">ES</span>
          </button>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-inner">
          <span>&copy; 2026 Emmanuel Gutierrez Pizarro - JP Asesores S.R.L.</span>
          <ul class="footer-links">
            <li><a href="https://linkedin.com/in/emmanuelgpcr" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href="mailto:jgutierrez@jpasesorescr.com">Email</a></li>
          </ul>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle
      document.getElementById('themeToggle').addEventListener('click', function () {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        }
      });

      // Language toggle
      function syncLangLabel() {
        var lang = document.documentElement.getAttribute('data-site-lang');
        document.getElementById('langLabel').textContent = lang === 'es' ? 'EN' : 'ES';
      }
      syncLangLabel();
      document.getElementById('langSwitch').addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-site-lang');
        var next = current === 'es' ? 'en' : 'es';
        document.documentElement.setAttribute('data-site-lang', next);
        document.documentElement.setAttribute('lang', next);
        localStorage.setItem('siteLang', next);
        syncLangLabel();
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
